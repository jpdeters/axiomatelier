---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

// 1. Get the current page URL and props
const { title = "Latent Form Theory", image = "/images/default-share-image.jpg" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// 2. Dynamic Fallback Logic tailored for Latent Form Theory
let description = Astro.props.description;

if (!description) {
  const path = Astro.url.pathname.replace(/\/$/, ""); // Cleans up trailing slashes
  
  if (path === "" || path === "/") {
    description = "Exploring the intersection of art, geometry, and design philosophy.";
  } else if (path.includes("essays")) {
    description = `Read our latest design essay "${title}"—exploring art, depth, and creative theory.`;
  } else if (path.includes("gallery")) {
    description = `Browse the visual portfolio, geometric forms, and structural artwork collections.`;
  } else if (path.includes("theory")) {
    description = `An in-depth look into the core philosophies and frameworks of Latent Form Theory.`;
  } else if (path.includes("about")) {
    description = `Learn more about the intent, vision, and origins behind Latent Form Theory.`;
  } else {
    // Catch-all safety fallback using the current page title
    description = `Discover ${title}—essays and perspectives on structural art and modern design theory.`;
  }
}
---

<html lang="en">
  <head>
    <!-- Essential Global Meta Tags -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter Preview Tags -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />
  </head>

  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style>
  body {
    margin: 0;
    background: #faf9f6;
    color: #161616;
    font-family: Georgia, serif;
  }

  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
  }
</style>